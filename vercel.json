{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/v1/cron/positions-resolution",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/v1/cron/equity-snapshot",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/v1/cron/sync-external-traders",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/v1/cron/creator-scores",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/v1/cron/follow-notifications",
      "schedule": "*/15 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
